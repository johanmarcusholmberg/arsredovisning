modules = ["nodejs-22", "python-3.11", "postgresql-16"]

[workflows]
runButton = "artifacts/web: web"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run dev"
waitForPort = 8081

[[workflows.workflow]]
name = "artifacts/web: web"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/arsredovisningar run dev"
waitForPort = 22133

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/web run dev"
waitForPort = 22333

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 22133
externalPort = 3000

[[ports]]
localPort = 22333
externalPort = 3001

[nix]
channel = "stable-25_05"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[agent]
expertMode = true
