{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*", "mockupPreviewPlugin.ts", "vite.config.ts"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "noEmit": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@/i18n/*": ["../arsredovisningar/src/i18n/*"],
      "@/hooks/useLanguage": ["../arsredovisningar/src/hooks/useLanguage"],
      "@/contexts/languageContextValue": ["../arsredovisningar/src/contexts/languageContextValue"],
      "@/contexts/LanguageContext": ["../arsredovisningar/src/contexts/LanguageContext"],
      "@/*": ["./src/*"]
    }
  }
}
