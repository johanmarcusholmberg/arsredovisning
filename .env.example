# =============================================================================
# Environment Variables — Årsredovisningar
# =============================================================================
#
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to version control.
#
# Annotation key:
#   [SERVER-ONLY]  — Must NEVER be exposed to the browser. Keep server-side only.
#                    Never prefix with VITE_. Never import in frontend code.
#   [CLIENT-SAFE]  — Safe to expose to the browser. Use VITE_ prefix for Vite apps.
#   [REQUIRED]     — The server will refuse to start without this variable.
#   [OPTIONAL]     — The server starts without this, but the feature will be disabled.
#   [PLACEHOLDER]  — Not yet integrated. Set for future phases.
#
# =============================================================================

# =============================================================================
# Core Server Configuration
# =============================================================================

# [SERVER-ONLY] [REQUIRED]
# Port the Express server listens on. Set by Replit workflows automatically.
PORT=3000

# [SERVER-ONLY] [REQUIRED]
# Node environment. "development" enables pretty logs and disables some caches.
NODE_ENV=development

# [SERVER-ONLY] [OPTIONAL]
# Pino log level. Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# =============================================================================
# Database
# =============================================================================

# [SERVER-ONLY] [REQUIRED]
# PostgreSQL connection string. Provisioned automatically by Replit.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# =============================================================================
# Supabase
# =============================================================================
# Create a project at https://supabase.com
# Project Settings → API to find these values.

# [CLIENT-SAFE] [REQUIRED for Supabase Auth]
# The public-facing Supabase project URL. Safe to expose to the browser.
# Used by the frontend Supabase client for Auth operations.
VITE_SUPABASE_URL=https://your-project.supabase.co

# [CLIENT-SAFE] [REQUIRED for Supabase Auth]
# The Supabase anonymous key. Safe to expose to the browser.
# Has severely limited permissions — RLS policies enforce all data access.
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# [SERVER-ONLY] [REQUIRED for Supabase Auth + Storage]
# !! WARNING: This key bypasses ALL Row Level Security policies. !!
# !! NEVER expose this to the browser or include it in frontend bundles. !!
# !! NEVER prefix this with VITE_. !!
# Used by the Express server for: Auth token verification, Storage signed URL
# generation, and service-role database operations (audit logging, entitlements).
# Found at: Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# [SERVER-ONLY] [REQUIRED for Supabase Auth + Storage]
# Same value as VITE_SUPABASE_URL — duplicated here for server-side use
# without a VITE_ prefix (keeping the server bundle lean).
SUPABASE_URL=https://your-project.supabase.co

# =============================================================================
# Session
# =============================================================================

# [SERVER-ONLY] [REQUIRED]
# Secret used to sign Express sessions. Generate with: openssl rand -hex 32
# Minimum 32 characters. Changing this invalidates all existing sessions.
SESSION_SECRET=change-me-to-a-long-random-string

# =============================================================================
# Stripe (placeholder — Phase 4)
# =============================================================================

# [SERVER-ONLY] [PLACEHOLDER]
# Stripe secret key for payment processing. sk_test_ prefix for test mode.
# !! NEVER expose to the browser or prefix with VITE_. !!
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder

# [CLIENT-SAFE] [PLACEHOLDER]
# Stripe publishable key — safe to expose to the browser.
# Found at: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# [SERVER-ONLY] [PLACEHOLDER]
# Stripe webhook signing secret. Used to verify incoming webhook payloads.
# Found at: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# =============================================================================
# AI Provider (placeholder — Phase 5)
# =============================================================================

# [SERVER-ONLY] [PLACEHOLDER]
# OpenAI API key for AI-assisted note generation and mapping suggestions.
# !! NEVER expose to the browser or prefix with VITE_. !!
# Found at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-placeholder

# =============================================================================
# Export Service (placeholder — Phase 7)
# =============================================================================

# [SERVER-ONLY] [PLACEHOLDER]
# Base URL for the PDF/Word export rendering service.
# Internal service — not exposed to the browser.
EXPORT_SERVICE_URL=http://localhost:4001

# [SERVER-ONLY] [PLACEHOLDER]
# API key for authenticating with the export service.
# !! NEVER expose to the browser or prefix with VITE_. !!
EXPORT_SERVICE_KEY=placeholder
